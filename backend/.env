# ── Roboflow Settings ─────────────────────────────
# Get this from: https://app.roboflow.com → Settings → Roboflow API
ROBOFLOW_API_KEY=NcZZtYzMxNxEOlCXkJMb

# Your Roboflow project ID (from the URL)
# e.g. https://app.roboflow.com/chinrajs-workspace/my-first-project-lca2k
ROBOFLOW_MODEL_ID=my-first-project-lca2k

# Version number of your trained model (check Roboflow → Versions)
ROBOFLOW_VERSION=1

# ── Detection Settings ────────────────────────────
CONFIDENCE_THRESHOLD=0.5
MAX_IMAGE_SIZE_MB=10
DEBUG=True